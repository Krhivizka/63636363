using System;

class Program
{
    static void Main()
    {
        // Исходный текст, который анализируем
        string text = @"«Да, здесь, в этом лесу, был этот дуб, с которым мы были согласны, — подумал князь Андрей. — Да где он?» — подумал опять князь Андрей, глядя на левую сторону дороги и, сам того не зная,
не узнавая его, любовался тем дубом, которого он искал.
Старый дуб, весь преображённый, раскинувшись шатром сочной, тёмной зелени, млел, чуть колыхаясь в лучах вечернего солнца. Ни корявых пальцев, ни болячек, ни старого горя и недоверия — ничего не было видно.
Сквозь столетнюю жёсткую кору пробились без сучков сочные, молодые листья, так что верить нельзя было, что это старик произвёл их.
«Да это тот самый дуб», — подумал князь Андрей, и на него вдруг нашло беспричинное весеннее чувство радости и обновления. Все лучшие минуты его жизни вдруг в одно и то же время вспомнились ему.
И Аустерлиц с высоким небом, и мёртвое укоризненное лицо жены, и Пьер на пароме, и девочка, взволнованная красотою ночи, и эта ночь, и луна — и всё это вдруг вспомнилось ему.
«Нет, жизнь не кончена и тридцать один год, — вдруг окончательно беспеременно решил князь Андрей.
— Мало того, что я знаю всё то, что есть во мне, надо, чтоб и все знали это: и Пьер, и эта девочка, которая хотела улететь в небо, надо, чтобы все знали меня, чтобы не для одного меня шла моя жизнь,
чтобы не жили они так, как эта девочка, независимо от моей жизни, чтобы на всех она отражалась и чтобы все они жили со мною вместе!».";

        // Указатель 1: разделение текста на строки по символам новой строки
        string[] lines = text.Split(new[] { "\r\n", "\n" }, StringSplitOptions.None);

        // Указатель 2: подсчет общего количества символов во всем тексте
        int totalChars = 0;
        foreach (var line in lines)
        {
            totalChars += line.Length; // Указатель 3: добавление длины каждой строки к общему счетчику
        }

        // Вывод результата подсчета символовов
        Console.WriteLine($"Общее количество символов в тексте: {totalChars}");

        // Указатель 4: слова для поиска в строках
        string[] searchWords = { "Пример", "тест", "строки" };

        // Указатель 5: поиск и вывод строк, начинающихся или заканчивающихся на указанные слова
        Console.WriteLine("\nСтроки, начинающиеся или заканчивающиеся на указанные слова:");
        foreach (var line in lines)
        {
            foreach (var word in searchWords)
            {
                // Указатель 6: проверка, начинается ли строка с искомого слова (игнорировать регистр)
                if (line.StartsWith(word, StringComparison.OrdinalIgnoreCase))
                {
                    Console.WriteLine($"Начинается на '{word}': {line}");
                }
                // Указатель 7: проверка, заканчивается ли строка на искомое слово (игнорировать регистр)
                if (line.EndsWith(word, StringComparison.OrdinalIgnoreCase))
                {
                    Console.WriteLine($"Заканчивается на '{word}': {line}");
                }
            }
        }
    }
}
