using System;

class Calculator
{
    // Метод сложения двух целых чисел
    public int Add(int a, int b)
    {
        return a + b;
    }

    // Перегруженный метод сложения трёх целых чисел
    public int Add(int a, int b, int c)
    {
        return a + b + c;
    }

    // Перегруженный метод сложения двух чисел с плавающей точкой
    public double Add(double a, double b)
    {
        return a + b;
    }
}

class Program
{
    static void Main()
    {
        Calculator calc = new Calculator();

        Console.WriteLine(calc.Add(2, 3));           // Результат: 5
        Console.WriteLine(calc.Add(1, 2, 3));        // Результат: 6
        Console.WriteLine(calc.Add(2.5, 3.7));       // Результат: 6.2

        // Можно попробовать разные варианты с перегруженными методами
    }
}
