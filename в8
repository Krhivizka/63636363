	private: System::Void button1_Click(System::Object ^ sender, System::EventArgs ^ e) {
		// Плотность сосны (кг/м^3)
		double rho_sosna = 400.0;
		// Плотность воды (кг/м^3)
		double rho_water = 1000.0;

		// Считываем размеры из текстбоксов и переводим в числа
		double a = Double::Parse(textBox1->Text);
		double b = Double::Parse(textBox2->Text);
		double c = Double::Parse(textBox3->Text);

		// Переводим размеры в метры
		double a_m = a / 100.0;
		double b_m = b / 100.0;
		double c_m = c / 100.0;

		// Вычисляем объем бруска
		double volume_brusok = a_m * b_m * c_m;

		// Масса бруска
		double mass_brusok = rho_sosna * volume_brusok;

		// Вычисляем глубину погружения (h) в метрах
		double h_m = mass_brusok / (rho_water * a_m * b_m);

		// Переводим в сантиметры
		double h_cm = h_m * 100.0;

		// Выводим результат в лейбл
		label6->Text = "Глубина погружения: " + h_cm.ToString("F2") + " см";
	}

